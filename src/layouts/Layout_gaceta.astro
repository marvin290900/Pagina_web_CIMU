---
import "../styles/global.css";
import Footer from "../components/Footer.astro";

import cimuLogo from "../assets/logos/LogoConTextoCIMU.svg";
import uesLogoBlanco from "../assets/logos/uesLogoBlanco.svg";
import plumaLogo from "../assets/logos/logo_pluma_multi.png";
import submarcaCIMU from "../assets/logos/logo_submarca.png";
import gaceta from "../assets/logos/gaceta.png";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta name="generator" content={Astro.generator} />
    <title>Centro de Investigación - CIMU</title>
    <link
      href="https://cdn.materialdesignicons.com/7.2.96/css/materialdesignicons.min.css"
      rel="stylesheet"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header>
      <div class="w-full justify-center py-3 hidden lg:flex">
        <img src={gaceta.src} alt="Logo de gaceta" class="w-1/4" />
      </div>

      <!-- Barra de navegación -->
      <nav class="navbar bg-principal shadow-sm text-white">
        <div
          class="flex justify-between items-center w-full md:w-[80%] mx-auto px-4 md:px-0"
        >
          <!-- Logo móvil -->
          <div class="flex lg:hidden">
            <a href="/gaceta">
              <img src={gaceta.src} alt="logo gaceta" class="w-36" />
            </a>
          </div>

          <!-- Botón hamburguesa Premium -->
          <div class="lg:hidden">
            <button id="mobile-menu-button" class="btn btn-ghost text-black">
              <span class="mdi mdi-menu text-2xl"></span>
            </button>
          </div>

          <!-- Menú horizontal escritorio -->
          <div class="hidden lg:flex mx-auto">
            <ul class="flex w-full justify-center text-black gap-2">
              <li>
                <a href="/gaceta" class="nav-link px-4 py-2 rounded-md"
                  >Inicio</a
                >
              </li>
              <li>
                <a href="/gaceta/opinion" class="nav-link px-4 py-2 rounded-md"
                  >Opinión Multidisciplinaria</a
                >
              </li>
              <li>
                <a
                  href="/gaceta/actualidad"
                  class="nav-link px-4 py-2 rounded-md">Actualidad</a
                >
              </li>
              <li>
                <a
                  href="/gaceta/audiovisuales"
                  class="nav-link px-4 py-2 rounded-md">Audio visuales</a
                >
              </li>
              <li>
                <a
                  href="/gaceta/vida_universitaria"
                  class="nav-link px-4 py-2 rounded-md">Vida universitaria</a
                >
              </li>
              <li>
                <a href="/gaceta/memoria" class="nav-link px-4 py-2 rounded-md"
                  >Memoria colectiva</a
                >
              </li>
            </ul>
          </div>
        </div>
      </nav>

      <!-- Nuevo Menú Móvil (Full Screen) -->
      <div
        id="mobile-menu"
        class="fixed inset-0 bg-white z-[100] hidden overflow-y-auto animate-fade-in transition-all duration-300"
      >
        <div class="flex flex-col h-full min-h-screen p-8">
          <!-- Header del menú -->
          <div class="flex justify-between items-center mb-10">
            <div
              class="text-2xl font-black tracking-tighter text-red-950 uppercase"
            >
              GACETA MULTIDISCIPLINARIA
            </div>
            <button
              id="close-menu-button"
              class="text-red-950 hover:rotate-90 transition-transform duration-300"
            >
              <span class="mdi mdi-close text-4xl"></span>
            </button>
          </div>

          <!-- Links de Gaceta -->
          <nav class="flex flex-col space-y-6 pb-20">
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta">Inicio</a
            >
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta/opinion">Opinión Multidisciplinaria</a
            >
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta/actualidad">Actualidad</a
            >
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta/audiovisuales">Audio visuales</a
            >
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta/vida_universitaria">Vida universitaria</a
            >
            <a
              class="mobile-nav-link text-xl font-black tracking-tighter text-red-950 border-b border-gray-100 pb-2"
              href="/gaceta/memoria">Memoria colectiva</a
            >

            <!-- <div class="pt-10">
              <a
                href="/gaceta"
                class="mobile-nav-link block w-full bg-[#1D2D50] text-white px-8 py-5 rounded-2xl font-black text-xl text-center shadow-2xl transform active:scale-95 transition-transform duration-150"
              >
                Gaceta Digital
              </a>
            </div> -->
          </nav>
        </div>
      </div>
    </header>

    <main class="zoom-fade-in-up">
      <slot />
    </main>

    <Footer
      cimuLogo={cimuLogo}
      uesLogoBlanco={uesLogoBlanco}
      plumaLogo={plumaLogo}
      submarcaCIMU={submarcaCIMU}
    />

    <script is:inline>
      const mobileMenuButton = document.getElementById("mobile-menu-button");
      const closeMenuButton = document.getElementById("close-menu-button");
      const mobileMenu = document.getElementById("mobile-menu");
      const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

      function toggleMenu() {
        mobileMenu?.classList.toggle("hidden");
        document.body.classList.toggle("overflow-hidden");
      }

      mobileMenuButton?.addEventListener("click", toggleMenu);
      closeMenuButton?.addEventListener("click", toggleMenu);

      mobileNavLinks.forEach((link) => {
        link.addEventListener("click", () => {
          mobileMenu?.classList.add("hidden");
          document.body.classList.remove("overflow-hidden");
        });
      });
    </script>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: "Nunito", sans-serif;
  }

  @keyframes zoomFadeInUp {
    0% {
      opacity: 0;
      transform: translateY(30px) scale(0.95);
    }
    100% {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  .zoom-fade-in-up {
    animation: zoomFadeInUp 0.7s ease-out;
  }
  .nav-link {
    position: relative;
    transition: color 0.3s ease;
  }
  .nav-link::after {
    content: "";
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: #dc0f0f;
    transition: width 0.3s ease;
  }
  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .animate-fade-in {
    animation: fadeIn 0.3s ease-out forwards;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
