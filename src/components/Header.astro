---
const { cimuLogo, uesLogoBlanco, uesLogoRojo, decanato, plumaLogo, remiLogo } =
  Astro.props;
---

<!-- Se muestra cuando esta en laptop y tablet -->
<header
  id="mainHeader"
  class="w-full z-50 transition-colors duration-300 text-[#1D2D50] shadow-none"
>
  <!-- FILA 1 - LOGOS -->
  <div
    class="flex-col sm:flex-row items-center py-3 justify-center bg-white hidden sm:flex"
  >
    <!-- Logo + Texto -->
    <div class="items-center flex">
      <a href="/">
        <img
          src={cimuLogo.src}
          alt="cimuLogo"
          title="Centro de Investigación Multidisciplinario FMOcc UES"
          class="h-18 sm:h-18 md:h-18 lg:h-24 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>
    </div>

    <!-- Logos con divisor -->
    <div
      class="ml-1 sm:ml-1 md:ml-18 lg:ml-50 items-center gap-6 hidden sm:flex"
    >
      <a href="/" class="flex flex-row sm:flex-row items-center h-20">
        <img
          id="plumaLogo"
          title="Editorial de la FMocc - UES"
          src={plumaLogo.src}
          alt="plumaLogo"
          class="h-10 sm:h-10 md:h-10 lg:h-15 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>

      <a href="/" class="flex items-center h-20">
        <img
          id="remiLogo"
          title="Revista Multidisciplinaria de Investigación"
          src={remiLogo.src}
          alt="remiLogo"
          class="h-8 sm:h-8 md:h-8 lg:h-12 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>

      <a href="/" class="flex items-center h-20">
        <img
          id="decanatoLogo"
          title="Decanato FMOcc - UES"
          src={decanato.src}
          alt="decanatoLogo"
          class="h-10 sm:h-10 md:h-10 lg:h-15 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>

      <a href="/" class="flex items-center h-20">
        <img
          src={uesLogoRojo.src}
          alt="uesLogo"
          title="Universidad de El Salvador"
          class="h-10 sm:h-10 md:h-10 lg:h-15 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>
    </div>
  </div>

  <!-- FILA 2 - MENU -->
  <!-- Menú para pantallas grandes -->
  <div class="flex items-center justify-center py-1 bg-gray-100 text-[#1D2D50]">
    <!-- Menu para pantallas grandes -->
    <div class="hidden sm:block mr-10 md:mr-5">
      <ul class="menu menu-horizontal px-1" id="menuPrincipal">
        <li><a href="/">Inicio</a></li>
        <li class="group relative">
          <a class="">Nosotros </a>
          <ul
            class="absolute left-0 top-full bg-white text-black rounded-md opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition duration-300 p-2 shadow-md z-50"
          >
            <li>
              <a
                href="/nosotros/acerca_de_cimu"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Acerca de CIMU</a
              >
            </li>

            <li>
              <a
                href="/nosotros/investigadores"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Investigadores/as</a
              >
            </li>
          </ul>
        </li>

        <li>
          <a href="/gaceta">Gaceta Multidisciplinaria</a>
        </li>

        <li class="group relative">
          <a class="">Investigaciones </a>
          <ul
            class="absolute left-0 top-full bg-white text-black rounded-md opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition duration-300 p-2 shadow-md z-50"
          >
            <li>
              <a
                href="/investigaciones/programa_de_investigaciones"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Programas de Investigación</a
              >
            </li>
          </ul>
        </li>

        <li class="group relative">
          <a class="">Publicaciones</a>
          <ul
            class="absolute left-0 top-full bg-white text-black rounded-md opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition duration-300 p-2 shadow-md z-50"
          >
            <li>
              <a
                href="/publicaciones/multidisciplinaria/multidisciplinaria_editorial"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Multidisciplinaria Editorial</a
              >
            </li>
          </ul>
        </li>
        <!-- Nuevo -->
        <li class="group relative">
          <a class="">REMI </a>
          <ul
            class="absolute left-0 top-full bg-white text-black rounded-md opacity-0 group-hover:opacity-100 pointer-events-none group-hover:pointer-events-auto transition duration-300 p-2 shadow-md z-50"
            style="width: 150px"
          >
            <li>
              <a
                href="/remi/remi"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >REMI</a
              >
            </li>
            <li>
              <a
                href="/remi/sobre_la_revista"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Sobre la revista</a
              >
            </li>
            <li>
              <a
                href="/remi/autoridades"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Autoridades Universitarias</a
              >
            </li>
            <li>
              <a
                href="/remi/editorial"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Equipo Editorial</a
              >
            </li>
            <li>
              <a
                href="/remi/envios"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Envios</a
              >
            </li>
            <li>
              <a
                href="/remi/sistema_de_revision"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Sistema de Revision</a
              >
            </li>
            <li>
              <a
                href="/remi/contacto"
                class="block px-4 py-2 rounded-md hover:bg-gray-200 hover:text-black transition duration-200"
                >Contacto</a
              >
            </li>
          </ul>
        </li>

        <li><a href="/contactenos">Contáctenos</a></li>
      </ul>
    </div>

    <!-- Menú para móvil -->
    <div class="flex sm:hidden relative justify-between items-center w-[90%]">
      <a href="/">
        <img
          src={cimuLogo.src}
          alt="cimuLogo"
          title="Centro de Investigación Multidisciplinario FMOcc UES"
          class="w-[80%] h-18 sm:h-18 md:h-18 lg:h-24 transition-all duration-300 hover:scale-105 hover:brightness-110"
        />
      </a>

      <!-- Botón hamburguesa -->
      <button id="mobile-menu-button" class="btn btn-square btn-ghost">
        <span class="mdi mdi-menu text-2xl"></span>
      </button>
    </div>
  </div>

  <!-- Menú desplegable a pantalla completa con navegación completa -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[100] hidden overflow-y-auto animate-fade-in transition-all duration-300"
  >
    <div class="flex flex-col h-full min-h-screen p-8">
      <!-- Header del menú -->
      <div class="flex justify-between items-center mb-10">
        <div
          class="text-2xl font-black tracking-tighter text-[#1D2D50] uppercase"
        >
          CIMU
        </div>
        <button
          id="close-menu-button"
          class="text-[#1D2D50] hover:rotate-90 transition-transform duration-300"
        >
          <span class="mdi mdi-close text-4xl"></span>
        </button>
      </div>

      <!-- Links del menú -->
      <nav class="flex flex-col space-y-6 pb-20">
        <!-- Inicio -->
        <a
          class="mobile-nav-link text-xl font-black tracking-tighter text-[#1D2D50] border-b border-gray-100 pb-2"
          href="/">Inicio</a
        >

        <!-- Nosotros -->
        <details class="group">
          <summary
            class="flex justify-between items-center cursor-pointer text-xl font-black tracking-tighter text-[#1D2D50] list-none border-b border-gray-100 pb-2 focus:outline-none"
          >
            Nosotros
            <span
              class="mdi mdi-chevron-down transition-transform duration-300 group-open:rotate-180"
            ></span>
          </summary>
          <div
            class="flex flex-col gap-4 pl-6 mt-4 border-l-4 border-[#1D2D50]"
          >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/nosotros/acerca_de_cimu">Acerca de CIMU</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/nosotros/investigadores">Investigadores/as</a
            >
          </div>
        </details>

        <!-- Gaceta -->
        <a
          class="mobile-nav-link text-xl font-black tracking-tighter text-[#1D2D50] border-b border-gray-100 pb-2"
          href="/gaceta">Gaceta</a
        >

        <!-- Investigaciones -->
        <details class="group">
          <summary
            class="flex justify-between items-center cursor-pointer text-xl font-black tracking-tighter text-[#1D2D50] list-none border-b border-gray-100 pb-2 focus:outline-none"
          >
            Investigaciones
            <span
              class="mdi mdi-chevron-down transition-transform duration-300 group-open:rotate-180"
            ></span>
          </summary>
          <div
            class="flex flex-col gap-4 pl-6 mt-4 border-l-4 border-[#1D2D50]"
          >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/investigaciones/programa_de_investigaciones"
              >Programas de Investigación</a
            >
          </div>
        </details>

        <!-- Publicaciones -->
        <details class="group">
          <summary
            class="flex justify-between items-center cursor-pointer text-xl font-black tracking-tighter text-[#1D2D50] list-none border-b border-gray-100 pb-2 focus:outline-none"
          >
            Publicaciones
            <span
              class="mdi mdi-chevron-down transition-transform duration-300 group-open:rotate-180"
            ></span>
          </summary>
          <div
            class="flex flex-col gap-4 pl-6 mt-4 border-l-4 border-[#1D2D50]"
          >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/publicaciones/multidisciplinaria/multidisciplinaria_editorial"
              >Multidisciplinaria Editorial</a
            >
          </div>
        </details>

        <!-- REMI -->
        <details class="group">
          <summary
            class="flex justify-between items-center cursor-pointer text-xl font-black tracking-tighter text-[#1D2D50] list-none border-b border-gray-100 pb-2 focus:outline-none"
          >
            REMI
            <span
              class="mdi mdi-chevron-down transition-transform duration-300 group-open:rotate-180"
            ></span>
          </summary>
          <div
            class="flex flex-col gap-4 pl-6 mt-4 border-l-4 border-[#1D2D50]"
          >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/remi">REMI</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/sobre_la_revista">Sobre la revista</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/autoridades">Autoridades Universitarias</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/editorial">Equipo Editorial</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/envios">Envíos</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/sistema_de_revision">Sistema de Revisión</a
            >
            <a
              class="mobile-nav-link text-xl font-bold text-[#1D2D50]/80"
              href="/remi/contacto">Contacto</a
            >
          </div>
        </details>

        <!-- Contáctenos -->
        <div class="pt-10">
          <a
            href="/contactenos"
            class="mobile-nav-link block w-full bg-[#1D2D50] text-white px-8 py-5 rounded-2xl font-black text-xl text-center shadow-2xl transform active:scale-95 transition-transform duration-150"
          >
            Contáctenos
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script is:inline>
  // Cierra todos los submenús cuando se hace clic en un enlace
  document.querySelectorAll("#menuPrincipal a").forEach((link) => {
    link.addEventListener("click", () => {
      document.querySelectorAll("#menuPrincipal li ul").forEach((submenu) => {
        submenu.classList.remove("opacity-100", "pointer-events-auto");
        submenu.classList.add("opacity-0", "pointer-events-none");
      });
    });
  });

  // Cierra submenús al cambiar de página
  window.addEventListener("beforeunload", () => {
    document.querySelectorAll("#menuPrincipal li ul").forEach((submenu) => {
      submenu.classList.remove("opacity-100", "pointer-events-auto");
      submenu.classList.add("opacity-0", "pointer-events-none");
    });
  });

  const mobileMenuButton = document.getElementById("mobile-menu-button");
  const closeMenuButton = document.getElementById("close-menu-button");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

  function toggleMenu() {
    mobileMenu?.classList.toggle("hidden");
    document.body.classList.toggle("overflow-hidden");
  }

  mobileMenuButton?.addEventListener("click", toggleMenu);
  closeMenuButton?.addEventListener("click", toggleMenu);

  mobileNavLinks.forEach((link) => {
    link.addEventListener("click", () => {
      mobileMenu?.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    });
  });
</script>
