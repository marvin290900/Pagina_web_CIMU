<!-- Overlay oscuro -->
<div
  id="sidebarOverlay"
  class="fixed inset-0 bg-[#6B72804D] z-40 hidden transition-opacity duration-300"
>
</div>

<!-- Sidebar (oculto por defecto) -->
<aside
  id="sidebar"
  class="fixed top-0 left-0 w-64 h-full bg-gray-800 text-white transform -translate-x-full transition-transform duration-300 z-50"
>
  <!-- Título + botón cerrar -->
  <div class="flex items-center justify-between p-4 border-b border-gray-700">
    <span class="font-bold text-lg">Navegación</span>
    <button id="closeSidebar" class="text-white text-xl hover:text-red-400">
      <span class="mdi mdi-close"></span>
    </button>
  </div>

  <!-- Menú de navegación -->
  <nav class="flex flex-col p-4 space-y-2 flex-1">
    <a
      href="/admin/inicio"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-home"></span> Inicio
    </a>
    <a
      href="/admin/investigadores"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-account-group-outline"></span> Investigadores/as
    </a>
    <a
      href="/admin/gaceta"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-post-outline"></span> Gaceta Multidisciplinaria
    </a>
    <a
      href="/admin/investigacion"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-file-document-multiple-outline"></span> Investigaciones
    </a>
    <a
      href="/admin/libros"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-school-outline"></span> Multidisciplinaria Editorial
    </a>
    <a
      href="/admin/carrousel_imagenes"
      class="hover:bg-gray-700 rounded px-3 py-2 flex items-center gap-2"
    >
      <span class="mdi mdi-image-multiple"></span> Carrusel de Imágenes
    </a>
  </nav>

  <!-- Cerrar sesión -->
  <div class="p-4 border-t border-gray-700">
    <button
      class="hover:bg-red-600 hover:text-white rounded px-3 py-2 flex items-center gap-2 text-red-400"
      id="logoutBtn"
    >
      <span class="mdi mdi-logout"></span> Cerrar Sesión</button
    >
  </div>
</aside>

<!-- Encabezado principal -->
<header
  id="mainHeader"
  class="navbar fixed top-0 left-0 w-full z-40 bg-gray-900 text-white shadow"
>
  <div class="w-full flex items-center justify-between px-4 md:px-6 h-10">
    <div class="flex items-center gap-3">
      <!-- Botón para mostrar el sidebar -->
      <button
        id="toggleSidebar"
        class="btn btn-sm btn-ghost text-white focus:outline-none mdi mdi-menu text-2xl hover:bg-blue-950"
      ></button>

      <!-- Título -->
      <a
        href="/admin/informacion"
        class="text-xs sm:text-xs md:text-lg lg:text-lg font-bold uppercase"
        >Panel de Administración</a
      >
    </div>

    <!-- Avatar usuario -->
    <!-- <div class="flex items-center">
      <div class="w-10 h-10 rounded-full overflow-hidden border-2 border-white">
        <img
          src="https://i.pravatar.cc/150?img=3"
          alt="Usuario logueado"
          class="w-full h-full object-cover"
        />
      </div>
    </div> -->
  </div>
</header>

<!-- Scripts -->
<script>
  // Función para inicializar los eventos
  const setupNavbar = () => {
    const sidebar = document.getElementById("sidebar");
    const toggleSidebar = document.getElementById("toggleSidebar");
    const closeSidebar = document.getElementById("closeSidebar");
    const overlay = document.getElementById("sidebarOverlay");
    const logoutBtn = document.getElementById("logoutBtn");

    const openSidebar = () => {
      sidebar?.classList.remove("-translate-x-full");
      sidebar?.classList.add("translate-x-0");
      overlay?.classList.remove("hidden");
    };

    const hideSidebar = () => {
      sidebar?.classList.add("-translate-x-full");
      sidebar?.classList.remove("translate-x-0");
      overlay?.classList.add("hidden");
    };

    // Evento Logout
    if (logoutBtn) {
      logoutBtn.onclick = async (e) => {
        e.preventDefault();
        console.log("Se clickeó cerrar sesión - Enviando petición...");

        try {
          const response = await fetch("/api/logout", { method: "POST" });
          if (response.ok) {
            console.log("Sesión cerrada en el servidor");
            window.location.href = "/login";
          } else {
            console.error("Error al cerrar sesión:", response.statusText);
          }
        } catch (err) {
          console.error("Error de red:", err);
        }
      };
    }

    // Eventos de UI
    toggleSidebar?.addEventListener("click", openSidebar);
    closeSidebar?.addEventListener("click", hideSidebar);
    overlay?.addEventListener("click", hideSidebar);
  };

  // Ejecutar al cargar la página
  setupNavbar();

  // Si usas ViewTransitions de Astro, descomenta la siguiente línea:
  // document.addEventListener('astro:after-swap', setupNavbar);
</script>
